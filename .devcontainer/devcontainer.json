{
  "name": "Nerdschool - Introduction to databases",
  "image": "mcr.microsoft.com/devcontainers/java:17",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "none",
      "installMaven": "true"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "forwardPorts": [5432, 7777, 8080],
  "portsAttributes": {
    "5432": { "label": "PostgreSQL" },
    "7777": { "label": "pgAdmin", "visibility": "public" },
    "8080": { "label": "Spring Boot App", "visibility": "public" }
  },
  "remoteUser": "vscode",
  "postStartCommand": "docker run --privileged --rm tonistiigi/binfmt --install arm64 2>/dev/null || true",
  "postCreateCommand": "mvn dependency:resolve",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-spring-boot-dashboard"
      ]
    }
  }
}
